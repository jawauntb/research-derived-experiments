{
  "name": "@inquiry-black-box/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:check": "bun install --frozen-lockfile",
    "lint": "bun run scripts/lint.ts",
    "typecheck": "tsc -b",
    "test": "bun test apps/desktop/tests apps/extension/tests apps/cloud/tests packages/schema/tests packages/signals/tests",
    "test:e2e": "bun test tests/e2e/*.ts",
    "demo:fixture": "bun run test:e2e",
    "build:desktop": "bun run --cwd apps/desktop build",
    "build:extension": "bun run --cwd apps/extension build",
    "build:prototype": "bun run build:desktop && bun run build:extension",
    "dev:desktop": "bun run --cwd apps/desktop dev",
    "dev:extension": "bun run --cwd apps/extension build",
    "dev:cloud": "bun run --cwd apps/cloud dev",
    "modal-check": "cd modal && python3 -m pytest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.2"
  }
}
