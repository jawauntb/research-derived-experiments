{
  "manifest_version": 3,
  "name": "Inquiry Black Box",
  "version": "0.1.0",
  "description": "Local-first browser telemetry for Inquiry Black Box research sessions.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Inquiry Black Box",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "alarms", "storage", "scripting", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "optional_host_permissions": [],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
