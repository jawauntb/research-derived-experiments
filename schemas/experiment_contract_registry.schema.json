{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jawauntb/research-derived-experiments/schemas/experiment_contract_registry.schema.json",
  "title": "Experiment contract registry",
  "description": "Single authoritative partition of every direct research package into structured-manifest coverage or a time-bounded legacy exception, plus explicit run bindings for structured packages. Package coverage and run coverage are different facts: a root manifest proves at least one structured contract exists, not that every historical run is structured. Legacy exceptions are migration metadata and must never carry scientific status.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "excluded_packages", "frozen_legacy", "packages"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "kind": { "const": "experiment contract registry" },
    "excluded_packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/package_id" },
      "uniqueItems": true
    },
    "frozen_legacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cutoff_commit", "frozen_on", "packages", "sha256"],
      "properties": {
        "cutoff_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "frozen_on": { "$ref": "#/$defs/iso_date" },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/package_id" },
          "uniqueItems": true
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/structured_package" },
          { "$ref": "#/$defs/legacy_package" }
        ]
      }
    }
  },
  "$defs": {
    "package_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$" },
    "iso_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "repo_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\.)[^\\\\]+$"
    },
    "structured_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "coverage_mode", "manifest_path", "run_coverage", "runs"],
      "properties": {
        "package": { "$ref": "#/$defs/package_id" },
        "coverage_mode": { "const": "structured_manifest" },
        "manifest_path": { "$ref": "#/$defs/repo_relative_path" },
        "primary_run_id": { "$ref": "#/$defs/package_id" },
        "run_coverage": { "enum": ["complete", "partial"] },
        "runs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/run_record" }
        }
      }
    },
    "run_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "publication_package",
        "runtime_package",
        "provenance_mode",
        "integrity_state",
        "report_paths",
        "claim_ids",
        "evidence_ids",
        "gate_verdict_paths"
      ],
      "properties": {
        "run_id": { "$ref": "#/$defs/package_id" },
        "publication_package": { "$ref": "#/$defs/package_id" },
        "runtime_package": { "$ref": "#/$defs/package_id" },
        "provenance_mode": { "enum": ["structured_manifest", "legacy_report"] },
        "integrity_state": {
          "description": "Execution validity only; a failed scientific gate never implies invalid.",
          "enum": ["valid", "invalid", "not_assessed"]
        },
        "manifest_path": { "$ref": "#/$defs/repo_relative_path" },
        "report_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repo_relative_path" },
          "uniqueItems": true
        },
        "claim_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{2,63}$" },
          "uniqueItems": true
        },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^EVID-[A-Z0-9][A-Z0-9_-]{2,63}$" },
          "uniqueItems": true
        },
        "gate_verdict_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo_relative_path" },
          "uniqueItems": true
        }
      }
    },
    "legacy_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "coverage_mode", "exception"],
      "properties": {
        "package": { "$ref": "#/$defs/package_id" },
        "coverage_mode": { "const": "legacy_exception" },
        "exception": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "owner",
            "reason_code",
            "explanation",
            "next_action",
            "granted_on",
            "review_date",
            "expiry_date",
            "legacy_cutoff_commit",
            "adjudication"
          ],
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "reason_code": {
              "enum": [
                "pre_manifest_publication",
                "multi_run_ambiguity",
                "scaffold_pending_contract"
              ]
            },
            "explanation": { "type": "string", "minLength": 1 },
            "next_action": { "type": "string", "minLength": 1 },
            "granted_on": { "$ref": "#/$defs/iso_date" },
            "review_date": { "$ref": "#/$defs/iso_date" },
            "expiry_date": { "$ref": "#/$defs/iso_date" },
            "legacy_cutoff_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
            "adjudication": {
              "const": "This exception records migration debt only; it does not adjudicate scientific claims."
            }
          }
        }
      }
    }
  }
}
