{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-derived-experiments.example/schemas/claim_registry.schema.json",
  "title": "Claim registry referencing program evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "claims"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "generated_by": {"type": "string", "minLength": 1},
    "claims": {
      "type": "array",
      "items": {"$ref": "#/$defs/claim"}
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "statement", "claim_tier", "status", "evidence_ids", "source_refs"],
      "properties": {
        "claim_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
        },
        "statement": {"type": "string", "minLength": 1},
        "claim_tier": {
          "type": "string",
          "enum": ["descriptive", "internal", "external", "causal", "theoretical"]
        },
        "status": {
          "type": "string",
          "enum": ["supported", "rejected", "open", "inconclusive"]
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^EVID-[A-Z0-9][A-Z0-9_-]{2,63}$"}
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
