{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-derived-experiments.example/schemas/experiment_manifest.schema.json",
  "title": "Versioned experiment package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "hypothesis",
    "claim_tier",
    "controls",
    "seeds",
    "runtime",
    "dependencies",
    "gates",
    "artifacts",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "claim_tier": {
      "type": "string",
      "enum": ["descriptive", "internal", "external", "causal", "theoretical"]
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/control"
      }
    },
    "seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "accepted",
        "rejected",
        "inconclusive",
        "superseded",
        "retired"
      ]
    }
  },
  "$defs": {
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_id", "description"],
      "properties": {
        "control_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_class", "command"],
      "properties": {
        "execution_class": {
          "type": "string",
          "enum": ["local_cpu", "local_gpu", "modal_gpu", "external"]
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "estimated_minutes": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "criterion"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
        },
        "criterion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "public"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "raw",
            "reduced",
            "summary",
            "figure",
            "paper",
            "provenance",
            "log",
            "model",
            "dataset",
            "other"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "public": {
          "type": "boolean"
        },
        "envelope_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.envelope\\.json$"
        }
      }
    }
  }
}
