# coherence-testbench — expected env vars.
# Real values come from Doppler; this file lists names only.
# Secrets never live in the repo (see parent .gitignore).

# --- inherited from parent repo (may already be in your Doppler project) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Modal (compute) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_WORKSPACE=
MODAL_ENVIRONMENT=

# --- Supabase (metadata / labels / experiment tracking / corpus index) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Logfire (pipeline traces + run metrics) ---
LOGFIRE_TOKEN=

# --- PostHog (product analytics — Phase 3 only, not used in Phase 0) ---
POSTHOG_API_KEY=
POSTHOG_HOST=

# --- coherence-testbench-specific ---
# Path where BBBD is cached as BIDS. Keep OFF the repo tree (large).
BBBD_CACHE_DIR=

# Where Phase-0 artifacts are dropped. Defaults to ./artifacts if unset.
COHERENCE_ARTIFACT_ROOT=
