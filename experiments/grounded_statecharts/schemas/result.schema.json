{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-derived-experiments.local/grounded_live_result.schema.json",
  "title": "Grounded harness public live result row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "run_id",
    "task_id",
    "family",
    "condition",
    "repeat_index",
    "adapter_id",
    "model_id",
    "provider_id",
    "false_completion",
    "task_success",
    "joint_success",
    "refusal",
    "invalid_transition",
    "recovery_success",
    "useful_autonomy",
    "call_count",
    "input_tokens",
    "output_tokens",
    "tool_calls",
    "latency_ms",
    "estimated_cost_usd",
    "budget_exhausted",
    "integrity",
    "task_digest",
    "harness_digest",
    "budget_digest",
    "checkpoint_digest",
    "result_digest",
    "event_count",
    "public_event_digests"
  ],
  "properties": {
    "episode_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "family": {
      "enum": ["artifact_completion", "recursive_constrained_tool_use"]
    },
    "condition": {
      "enum": [
        "direct_self_report",
        "statechart_g0",
        "statechart_g3",
        "envelope_only",
        "envelope_external_guards",
        "wrong_edge_guard"
      ]
    },
    "repeat_index": {"type": "integer", "minimum": 0},
    "adapter_id": {"enum": ["fixture", "live"]},
    "model_id": {"type": "string", "minLength": 1},
    "provider_id": {"type": "string", "minLength": 1},
    "false_completion": {"type": "boolean"},
    "task_success": {"type": "boolean"},
    "joint_success": {"type": "boolean"},
    "refusal": {"type": "boolean"},
    "invalid_transition": {"type": "boolean"},
    "recovery_success": {"type": "boolean"},
    "useful_autonomy": {"type": "boolean"},
    "call_count": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "tool_calls": {"type": "integer", "minimum": 0},
    "latency_ms": {"type": "integer", "minimum": 0},
    "estimated_cost_usd": {"type": "number", "minimum": 0},
    "budget_exhausted": {"type": "boolean"},
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_valid",
        "checkpoint_ok",
        "replay_ok",
        "sanitized",
        "budget_ok",
        "publishable"
      ],
      "properties": {
        "schema_valid": {"type": "boolean"},
        "checkpoint_ok": {"type": "boolean"},
        "replay_ok": {"type": "boolean"},
        "sanitized": {"type": "boolean"},
        "budget_ok": {"type": "boolean"},
        "publishable": {"type": "boolean"}
      }
    },
    "task_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "harness_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "budget_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "checkpoint_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "result_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event_count": {"type": "integer", "minimum": 0},
    "public_event_digests": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }
  }
}
